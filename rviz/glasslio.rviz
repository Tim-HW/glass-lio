Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Grid1
        - /Odometry1
        - /Local Map1
        - /Deskewed1
      Splitter Ratio: 0.5
    Tree Height: 511
  - Class: rviz_common/Transformation
    Name: Transformation
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
